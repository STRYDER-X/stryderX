pipeline {
    agent {
        label 'StryderX-Core'
    }

    stages {
        stage('Checkout') {
            steps {
                sh 'pwd'
                checkout scm
            }
        }
        
        stage('Start Docker Container') {
            steps {
                    sh 'make up ALLOW_HOST_CMDS=true'
            }
        }

        stage('Verify Docker Container running') {
            steps {
                sh 'docker container ls -a'
            }
        }
    }

    post {
        always {
            sh 'make down ALLOW_HOST_CMDS=true'
            sh 'make clean ALLOW_HOST_CMDS=true'
        }
    }
}
