pipeline {
    agent {
        dockerfile {
            filename 'Dockerfile.dev'
            dir 'stryderx_docker'
            reuseNode true
        }
        label 'StryderX-Core'
    }

    stages {
        stage('Verify Repo Copied Over') {
            steps {
                sh 'pwd'
                sh 'ls -ln'
            }
        }
    }
}
