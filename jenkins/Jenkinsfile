pipeline {
    agent {
        dockerfile {
            filename 'stryderx_docker/Dockerfile.dev'
            dir '.'
            reuseNode true
        }
    }

    stages {
        stage('Setup') {
            steps {
                sh 'make setup'
            }
        }

        stage('Lint') {
            steps {
                sh 'make lint'
            }
        }

        stage('Build') {
            steps {
                sh 'make build'
            }
        }

        stage('Test') {
            steps {
                sh 'make test'
            }
        }

        stage('Report') {
            steps {
                sh 'make report'
            }
        }
    }
}
