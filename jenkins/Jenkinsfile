pipeline {
    agent {
        dockerfile {
            filename 'stryderx_docker/Dockerfile'
            dir '.'
            reuseNode true
            label "${params.AGENT}"
        }
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        ansiColor('xterm')
    }

    parameters {
        choice {
            name: 'AGENT',
            choices: ['StryderX-Core', 'Linux'],
            descripition: 'Select the specific Agent for this to run on.'
        }
    }

    stages {
        stage('Lint') {
            steps {
                sh 'make lint'
            }
        }

        stage('Build') {
            steps {
                sh 'make build'
            }
        }

        stage('Test') {
            steps {
                sh 'make test'
            }
        }
    }

    post {
        always {
            node(env.NODE_NAME) {
                sh 'make report'
            }
        }
    }
}
