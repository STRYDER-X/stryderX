pipeline {
    agent {
        dockerfile {
            filename 'stryderx_docker/Dockerfile'
            dir '.'
            reuseNode true
            label "${params.AGENT}"
        }
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        ansiColor('xterm')
    }

    parameters {
        choice (
            name: 'AGENT',
            choices: ['StryderX-Core', 'Linux'],
            description: 'Select the specific Agent for this to run on.'
        )
    }

    stages {

        stage('Build') {
            steps {
                sh 'make build'
            }
        }

        stage('Test') {
            steps {
                sh 'make test'
            }
        }

        stage('Linter') {
            steps {
                sh 'make lint'
            }
        }

        stage('Report') {
            steps {
                sh 'make report'
            }
        }
    }
}
