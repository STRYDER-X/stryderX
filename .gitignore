# --- ROS 2 / Colcon Standard ---
# Ensure these are not tracked at the workspace root
/build/
/install/
/log/
/test_results/

# --- ROS 2 Tooling ---
COLCON_IGNORE
# These are generated by ament_lint during 'colcon test'
/ament_index/
.pytest_cache/

# --- C++ Artifacts ---
*.o
*.so
*.a
*.out
# Prevents committing local binaries if you build a package standalone
bin/
lib/

# --- Operating System / Editor Specific ---
.DS_Store
.idea/
.vscode/
# Ignore the hidden folders created by the C++ extension
.cache/
.clangd/

# --- Python Artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Logs and Temporary Files ---
*.log
*.tmp
*.bak
*~
# Ignore logs created by ROS 2 launch or rosbag
.ros/

# --- Environment and Secret Management ---
.env
.env.local