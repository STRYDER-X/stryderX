# ROS 2
/build/
/install/
/log/
/test_results/
COLCON_IGNORE
/ament_index/
.pytest_cache/

# C++ Artifacts
*.o
*.so
*.a
*.out
# Prevents committing local binaries if you build a package standalone
bin/
lib/

# Operating System / Editor Specific
.DS_Store
.idea/
.vscode/
.cache/
.clangd/

# Python Artifacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs and Temporary Files
*.log
*.tmp
*.bak
*~
# Ignore logs created by ROS 2 launch or rosbag
.ros/

# Documentation
**/docs/html/
**/docs/latex/
**/docs/xml/
*.tag

# Linter & Formatter Backups
*.uncrustify
.clang-format-check

# Global Workspace Protection
# Catches accidental local builds inside src/
**/build/
**/install/
**/log/
**/test_results/

# Build System Specifics
.cmake/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake

# Environment and Secret Management
.env
.env.local
